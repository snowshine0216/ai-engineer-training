OPENAI_BASE_URL=https://your-openai-compatible-endpoint.com/v1
OPENAI_API_KEY=your-api-key-here
DEFAULT_MODEL=gpt-4o-mini

# Demo mode — enables the demo-mode badge and injects a simulated failure on attempt 1
DEMO_MODE=false
# Best-effort per-process request limit for the shared public URL (resets each minute)
DEMO_REQUEST_BUDGET=50

# Langfuse — optional locally, configure for the deployed demo
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

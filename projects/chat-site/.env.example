OPENAI_BASE_URL=https://your-openai-compatible-endpoint.com/v1
OPENAI_API_KEY=your-api-key-here
DEFAULT_MODEL=gpt-4o-mini

# Required for the amap-weather tool (https://lbs.amap.com/)
AMAP_API_KEY=your-amap-api-key

# Required for the tavily-search tool (https://tavily.com/)
TAVILY_API_KEY=your-tavily-api-key

# Customer service multi-agent demo
CUSTOMER_SERVICE_DB_PATH=data/customer-service/customer-service.sqlite
SHOW_AGENT_TRACE=true

# Best-effort per-process request limit for the shared public URL (resets each minute)
DEMO_REQUEST_BUDGET=50

# Langfuse — optional locally, configure for the deployed demo
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Logging
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE_ENABLED=
